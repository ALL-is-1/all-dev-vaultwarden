#!/bin/bash
# OPTIONAL configure hook. Most all-dev-* snaps DON'T need one — they read config
# at runtime in snap/local/vaultwarden-run via `snapctl get`. Use this hook only to
# seed defaults or validate input at `snap set` time. Keep it defensive: it runs
# on install AND on every `snap set`, so it must never hard-fail on a half-set config.
set -e

# Seed defaults the first time, so `snap get all-dev-vaultwarden port` / `… bind` are populated.
# NB: use if-blocks, NOT `[ test ] && cmd` — under `set -e` the latter exits 1 (failing the
# whole hook + the install) whenever the key is ALREADY set (reinstall / partial config).
if [ -z "$(snapctl get port)" ]; then snapctl set port=28653; fi
# bind/listen address: 0.0.0.0 = LAN-reachable, 127.0.0.1 = loopback only
if [ -z "$(snapctl get bind)" ]; then snapctl set bind=0.0.0.0; fi

# Example validation (uncomment):
# port="$(snapctl get port)"
# if ! [ "$port" -ge 1 ] 2>/dev/null; then
#   echo "port must be a positive integer" >&2
#   exit 1
# fi
# bind="$(snapctl get bind)"
# case "$bind" in
#   0.0.0.0|127.0.0.1|::|::1) ;;   # allow the common cases
#   *[!0-9.]*|"") echo "bind must be an IP address" >&2; exit 1 ;;
# esac
